				<ConfidenceLevel>LEVEL_80</ConfidenceLevel>
				<ErrorPercent>0.5</ErrorPercent>
				<ExpressionForConfidenceComputation><![CDATA[0]]></ExpressionForConfidenceComputation>
			</ReplicationsProperties>
		</ParamVariationExperiment>
		<!--   =========  Parameter Variation Experiment   ========  -->
		<ParamVariationExperiment ActiveObjectClassId="1741363745426">
			<Id>1772476961214</Id>
			<Name><![CDATA[LHSParamVariation]]></Name>
			<Import><![CDATA[import java.io.*;]]></Import>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<InitialSetupCode><![CDATA[try {
	outputWriter = new BufferedWriter(new FileWriter("LHSVariationOutput.csv"));
	outputWriter.write(Main.get_output_headers());
} catch (IOException e) {
	getEngine().error(e, "Error opening output file");
}

var db = lhs_samples;
int num_variations = (int) selectFrom(db)
	.orderBy(db.run_id.desc())
	.firstResult(db.run_id);
	
traceln("Total variations: " + num_variations);]]></InitialSetupCode>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>fixedSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<BeforeSimulationRunCode><![CDATA[int iteration = getCurrentIteration() - 1;
var db = lhs_samples;

// ── Recruitment & Crime ───────────────────────────────────────────────
root.st_recruitment = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.st_recruitment);
root.crim_record_obstacle = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.crim_record_obstacle);
root.org_crime_prevalence = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.org_crime_prevalence);
root.trafficker_exposure = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.trafficker_exposure);
root.trafficking_educ = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.trafficking_educ);

// ── Population ────────────────────────────────────────────────────────
root.trafficked_pct_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.trafficked_pct_youth);
root.childhood_violence = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.childhood_violence);
root.geographic_csw_normalization = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.geographic_csw_normalization);

// ── Prosecution & Policy ──────────────────────────────────────────────
root.prosecution_culture = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.prosecution_culture);
root.prosecution_culture_v = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.prosecution_culture_v);
root.prosecution_culture_s = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.prosecution_culture_s);
root.prosecution_culture_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.prosecution_culture_youth);
root.prosecution_culture_youth_v = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.prosecution_culture_youth_v);
root.prosecution_culture_youth_s = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.prosecution_culture_youth_s);
root.buyer_prosecution_culture = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.buyer_prosecution_culture);
root.prosecution_mult = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.prosecution_mult);
root.pctExpungement = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.pct_expungement);

// ── Services — Adult ──────────────────────────────────────────────────
root.em_services_capacity = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.em_services_capacity);
root.st_services_capacity = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.st_services_capacity);
root.lt_services_capacity = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.lt_services_capacity);
root.em_services_recovery_rate = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.em_services_recovery_rate);
root.st_services_recovery_rate = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.st_services_recovery_rate);
root.lt_services_recovery_rate = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.lt_services_recovery_rate);

// ── Services — Youth ──────────────────────────────────────────────────
root.em_services_capacity_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.em_services_capacity_youth);
root.st_services_capacity_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.st_services_capacity_youth);
root.lt_services_capacity_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.lt_services_capacity_youth);
root.em_services_recovery_rate_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.em_services_recovery_rate_youth);
root.st_services_recovery_rate_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.st_services_recovery_rate_youth);
root.lt_services_recovery_rate_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.lt_services_recovery_rate_youth);

// ── Recovery & Recidivism — Adult ─────────────────────────────────────
root.base_adult_recovery_rate = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.base_adult_recovery_rate);
root.post_service_vulnerability = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.post_service_vulnerability);
root.vulnerable_recidivism = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.vulnerable_recidivism);

// ── Recovery & Recidivism — Youth ─────────────────────────────────────
root.base_youth_recovery_rate = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.base_youth_recovery_rate);
root.post_service_vulnerability_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.post_service_vulnerability_youth);
root.vulnerable_recidivism_youth = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.vulnerable_recidivism_youth);

// ── Supply/Demand & Economics ─────────────────────────────────────────
root.csw_acceptance = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.csw_acceptance);
root.csw_exhaustion = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.csw_exhaustion);
root.sb_benefit = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.sb_benefit);
root.ss_trns_pm = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.ss_trns_pm);
root.ss_desired_profit = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.ss_desired_profit);
root.trafficked_to_nontrafficked_pct = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.trafficked_to_nontrafficked_pct);
root.risk_cross_effect = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.risk_cross_effect);
root.sb_trns_risk_weight = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.sb_trns_risk_weight);
root.buyer_base_trns = (double) selectFrom(db)
    .where(db.run_id.eq(iteration))
    .firstResult(db.buyer_base_trns);]]></BeforeSimulationRunCode>
			<AfterSimulationRunCode><![CDATA[int iteration = getCurrentIteration() - 1;

String scenario = "" + iteration;
	
root.scenario_tag = scenario;

try {
	outputWriter.write(root.get_output());
}
 catch (IOException e) {
	getEngine().error(e, "Error writing output");
}]]></AfterSimulationRunCode>
			<SeedValue>1</SeedValue>
			<SelectionModeForSimultaneousEvents>LIFO</SelectionModeForSimultaneousEvents>
			<VmArgs><![CDATA[]]></VmArgs>
			<LoadRootFromSnapshot>false</LoadRootFromSnapshot>
			<Variables>
				<Variable Class="PlainVariable">
					<Id>1772477762669</Id>
					<Name><![CDATA[outputWriter]]></Name>
					<X>-120</X><Y>20</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties SaveInSnapshot="true" Constant="false" AccessType="public" StaticVariable="false">
						<Type><![CDATA[BufferedWriter]]></Type>        
					</Properties>
				</Variable>
			</Variables>


			<AfterExperimentCode><![CDATA[try {
	outputWriter.close();
} catch (IOException e) {
	getEngine().error(e, "Error closing output file");
}]]></AfterExperimentCode>
