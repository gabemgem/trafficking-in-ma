					<Body><![CDATA[StringBuilder sb = new StringBuilder();

// input
sb.append("pctExpungement");
sb.append(",");
sb.append("prosecution_culture");
sb.append(",");
sb.append("prosecution_culture_v");
sb.append(",");
sb.append("prosecution_culture_s");
sb.append(",");
sb.append("trafficker_exposure");
sb.append(",");
sb.append("geographic_csw_normalization");
