			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1745949285623</Id>
					<Name><![CDATA[orZero]]></Name>
					<X>-230</X><Y>40</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[val]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[return isFinite(val) ? val : 0.0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[String]]></ReturnType>
					<Id>1747332239654</Id>
					<Name><![CDATA[get_output]]></Name>
					<X>-250</X><Y>500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[StringBuilder sb = new StringBuilder();

sb.append(scenario_tag);
sb.append(",");

// input
sb.append(pctExpungement);
sb.append(",");
sb.append(prosecution_culture);
sb.append(",");
sb.append(prosecution_culture_v);
sb.append(",");
sb.append(prosecution_culture_s);
sb.append(",");
sb.append(trafficker_exposure);
sb.append(",");
sb.append(geographic_csw_normalization);
sb.append(",");
sb.append(crim_record_obstacle);
sb.append(",");
sb.append(em_services_capacity);
sb.append(",");
sb.append(st_services_capacity);
sb.append(",");
sb.append(lt_services_capacity);
sb.append(",");

sb.append(buyer_prosecution_culture);
sb.append(",");
sb.append(csw_acceptance);
sb.append(",");



// output
sb.append(TotalTSS);
sb.append(",");
sb.append(TotalSS);
sb.append(",");
sb.append(TotalYouthTSS);
sb.append(",");
sb.append(pctSSCrimRecord);
sb.append(",");
sb.append(pctExitedCrimRecord);
sb.append(",");
sb.append(TotalSS-TotalTSS);
sb.append(",");
sb.append(orZero(TotalTSS / TotalSS));
sb.append(",");

sb.append(EmServicesAdult);
sb.append(",");
sb.append(STServicesAdult);
sb.append(",");
sb.append(LTServicesAdult);
sb.append(",");

sb.append(Traffickers);
sb.append(",");
sb.append(Buyers);
sb.append(",");

sb.append(demand);
sb.append(",");
sb.append(cost);
sb.append(",");

sb.append(AdultRecidivism);
sb.append("\n");

return sb.toString();]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1758290874937</Id>
					<Name><![CDATA[check_equilibrium]]></Name>
					<X>-230</X><Y>690</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (pct_trafficked_collection.size() <= 1 || 
	pct_crim_record_collection.size() <= 1)
	return false;

double margin = 0.0001;

double pct_trafficked_first = pct_trafficked_collection.getFirst();
double pct_trafficked_last = pct_trafficked_collection.getLast();
double pct_crim_record_first = pct_crim_record_collection.getFirst();
double pct_crim_record_last = pct_crim_record_collection.getLast();

boolean equilibrium = abs(pct_trafficked_first-pct_trafficked_last) < margin &&
	abs(pct_crim_record_first-pct_crim_record_last) < margin;

//if (equilibrium) System.out.println("Found equilibrium at " + time());
if (stop_at_equilibrium && equilibrium) finishSimulation();
return equilibrium;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="true">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[String]]></ReturnType>
					<Id>1760106027415</Id>
					<Name><![CDATA[get_output_headers]]></Name>
					<X>-250</X><Y>520</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[StringBuilder sb = new StringBuilder();

sb.append("scenario");
sb.append(",");

// input
sb.append("pctExpungement");
sb.append(",");
sb.append("seller_prosecution_culture");
sb.append(",");
sb.append("prosecution_culture_v");
sb.append(",");
sb.append("prosecution_culture_s");
sb.append(",");
sb.append("trafficker_exposure");
sb.append(",");
sb.append("geographic_csw_normalization");
sb.append(",");
sb.append("crim_record_obstacle");
sb.append(",");
sb.append("em_services_capacity");
sb.append(",");
sb.append("st_services_capacity");
sb.append(",");
sb.append("lt_services_capacity");
sb.append(",");

sb.append("buyer_prosecution_culture");
sb.append(",");
sb.append("csw_acceptance");
sb.append(",");



// output
sb.append("TotalTSS");
sb.append(",");
sb.append("TotalSS");
sb.append(",");
sb.append("TotalYouthTSS");
sb.append(",");
sb.append("pctSSCrimRecord");
sb.append(",");
sb.append("pctExitedCrimRecord");
sb.append(",");
sb.append("TotalNonTraffickedSS");
sb.append(",");
sb.append("pctTraffickedVsNontrafficked");
sb.append(",");

sb.append("EmServicesAdult");
sb.append(",");
sb.append("STServicesAdult");
sb.append(",");
sb.append("LTServicesAdult");
sb.append(",");

sb.append("Traffickers");
sb.append(",");
sb.append("Buyers");
sb.append(",");

sb.append("demand");
sb.append(",");
sb.append("cost");
sb.append(",");

sb.append("AdultRecidivism");
sb.append("\n");

return sb.toString();]]></Body>
