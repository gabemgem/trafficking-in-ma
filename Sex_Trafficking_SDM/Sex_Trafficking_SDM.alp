		<!--   =========  Parameter Variation Experiment   ========  -->
		<ParamVariationExperiment ActiveObjectClassId="1741363745426">
			<Id>1760106555074</Id>
			<Name><![CDATA[PolicyVariation]]></Name>
			<Import><![CDATA[import java.io.*;]]></Import>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<InitialSetupCode><![CDATA[try {
	outputWriter = new BufferedWriter(new FileWriter("CSWPolicyScenarioOutput.csv"));
	outputWriter.write(Main.get_output_headers());
} catch (IOException e) {
	getEngine().error(e, "Error opening output file");
}]]></InitialSetupCode>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>fixedSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<BeforeSimulationRunCode><![CDATA[int iteration = getCurrentIteration() - 1;

String scenario = selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.scenario);
	
double buyer_prosecution_culture = (double) selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.buyer_prosecution_culture);
	
double seller_prosecution_culture = (double) selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.seller_prosecution_culture);
	
double pctExpungement = (double) selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.pct_expungement);
	
int em_services_capacity = (int) selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.em_services_capacity);
	
int st_services_capacity = (int) selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.st_services_capacity);
	
int lt_services_capacity = (int) selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.lt_services_capacity);
	
root.scenario_tag = scenario;
root.buyer_prosecution_culture = buyer_prosecution_culture;
root.prosecution_culture = seller_prosecution_culture;
root.pctExpungement = pctExpungement;
root.em_services_capacity = em_services_capacity;
root.st_services_capacity = st_services_capacity;
root.lt_services_capacity = lt_services_capacity;

System.out.println(scenario);]]></BeforeSimulationRunCode>
			<AfterSimulationRunCode><![CDATA[int iteration = getCurrentIteration() - 1;

String scenario = selectFrom(policyscenarios)
	.where(policyscenarios.index.eq(iteration))
	.firstResult(policyscenarios.scenario);
	
root.scenario_tag = scenario;

try {
	outputWriter.write(root.get_output());
}
 catch (IOException e) {
	getEngine().error(e, "Error writing output");
}]]></AfterSimulationRunCode>
			<SeedValue>1</SeedValue>
			<SelectionModeForSimultaneousEvents>LIFO</SelectionModeForSimultaneousEvents>
