			<Events>
				<Event>
					<Id>1758290542597</Id>
					<Name><![CDATA[record_data_for_equilibrium]]></Name>
					<X>-230</X><Y>660</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_MONTH]]></Unit>
						</Rate>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1758355200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[int max_vals = 5;

double pct_trafficked = orZero(TotalTSS / TotalSS);
double pct_crim_record = pctSSCrimRecord;

pct_trafficked_collection.add(pct_trafficked);
pct_crim_record_collection.add(pct_crim_record);

if(pct_trafficked_collection.size() > max_vals)
	pct_trafficked_collection.removeFirst();
if(pct_crim_record_collection.size() > max_vals)
	pct_crim_record_collection.removeFirst();]]></Action>
				</Event>
