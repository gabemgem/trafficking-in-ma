sb.append("st_services_capacity");
sb.append(",");
sb.append("lt_services_capacity");
sb.append(",");

sb.append("buyer_prosecution_culture");
sb.append(",");
sb.append("csw_acceptance");
sb.append(",");



// output
sb.append("TotalTSS");
sb.append(",");
sb.append("TotalSS");
sb.append(",");
sb.append("TotalYouthTSS");
sb.append(",");
sb.append("pctSSCrimRecord");
sb.append(",");
sb.append("pctExitedCrimRecord");
sb.append(",");
sb.append("TotalNonTraffickedSS");
sb.append(",");
sb.append("pctTraffickedVsNontrafficked");
sb.append(",");

sb.append("EmServicesAdult");
sb.append(",");
sb.append("STServicesAdult");
sb.append(",");
sb.append("LTServicesAdult");
sb.append(",");

sb.append("Traffickers");
sb.append(",");
sb.append("Buyers");
sb.append(",");

sb.append("demand");
sb.append(",");
sb.append("cost");
sb.append("\n");

return sb.toString();]]></Body>
