			<BeforeSimulationRunCode><![CDATA[int iteration = 1630;

// ── Recruitment & Crime ───────────────────────────────────────────────
root.st_recruitment = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.st_recruitment);
root.crim_record_obstacle = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.crim_record_obstacle);
root.org_crime_prevalence = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.org_crime_prevalence);
root.trafficker_exposure = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.trafficker_exposure);
root.trafficking_educ = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.trafficking_educ);

// ── Population ────────────────────────────────────────────────────────
root.trafficked_pct_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.trafficked_pct_youth);
root.childhood_violence = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.childhood_violence);
root.geographic_csw_normalization = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.geographic_csw_normalization);

// ── Prosecution & Policy ──────────────────────────────────────────────
root.prosecution_culture = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.prosecution_culture);
root.prosecution_culture_v = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.prosecution_culture_v);
root.prosecution_culture_s = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.prosecution_culture_s);
root.prosecution_culture_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.prosecution_culture_youth);
root.prosecution_culture_youth_v = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.prosecution_culture_youth_v);
root.prosecution_culture_youth_s = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.prosecution_culture_youth_s);
root.buyer_prosecution_culture = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.buyer_prosecution_culture);
root.prosecution_mult = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.prosecution_mult);
root.pctExpungement = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.pct_expungement);

// ── Services — Adult ──────────────────────────────────────────────────
root.em_services_capacity = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.em_services_capacity);
root.st_services_capacity = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.st_services_capacity);
root.lt_services_capacity = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.lt_services_capacity);
root.em_services_recovery_rate = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.em_services_recovery_rate);
root.st_services_recovery_rate = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.st_services_recovery_rate);
root.lt_services_recovery_rate = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.lt_services_recovery_rate);

// ── Services — Youth ──────────────────────────────────────────────────
root.em_services_capacity_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.em_services_capacity_youth);
root.st_services_capacity_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.st_services_capacity_youth);
root.lt_services_capacity_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.lt_services_capacity_youth);
root.em_services_recovery_rate_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.em_services_recovery_rate_youth);
root.st_services_recovery_rate_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.st_services_recovery_rate_youth);
root.lt_services_recovery_rate_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.lt_services_recovery_rate_youth);

// ── Recovery & Recidivism — Adult ─────────────────────────────────────
root.base_adult_recovery_rate = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.base_adult_recovery_rate);
root.post_service_vulnerability = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.post_service_vulnerability);
root.vulnerable_recidivism = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.vulnerable_recidivism);

// ── Recovery & Recidivism — Youth ─────────────────────────────────────
root.base_youth_recovery_rate = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.base_youth_recovery_rate);
root.post_service_vulnerability_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.post_service_vulnerability_youth);
root.vulnerable_recidivism_youth = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.vulnerable_recidivism_youth);

// ── Supply/Demand & Economics ─────────────────────────────────────────
root.csw_acceptance = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.csw_acceptance);
root.csw_exhaustion = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.csw_exhaustion);
root.sb_benefit = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.sb_benefit);
root.ss_trns_pm = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.ss_trns_pm);
root.ss_desired_profit = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.ss_desired_profit);
root.trafficked_to_nontrafficked_pct = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.trafficked_to_nontrafficked_pct);
root.risk_cross_effect = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.risk_cross_effect);
root.sb_trns_risk_weight = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.sb_trns_risk_weight);
root.buyer_base_trns = (double) selectFrom(lhs_samples)
    .where(lhs_samples.run_id.eq(iteration))
    .firstResult(lhs_samples.buyer_base_trns);]]></BeforeSimulationRunCode>
